# AI 模型配置
# ====================

# API 基础地址
# - Ollama (本地): http://localhost:11434/v1
# - OpenAI: https://api.openai.com/v1
# - 硅基流动: https://api.siliconflow.cn/v1
# - DeepSeek: https://api.deepseek.com/v1
# - 智谱AI: https://open.bigmodel.cn/api/paas/v4
LLM_API_BASE=http://localhost:11434/v1

# API 密钥
# - Ollama: 可以留空或使用 sk-placeholder
# - 其他服务: 填写你的 API Key
LLM_API_KEY=sk-placeholder

# 模型名称
# - Ollama: qwen2.5:7b, llama3.1:8b, mistral:7b 等
# - OpenAI: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
# - 硅基流动: Qwen/Qwen2.5-7B-Instruct, deepseek-ai/DeepSeek-V2.5
# - DeepSeek: deepseek-chat, deepseek-coder
# - 智谱AI: glm-4-flash, glm-4
LLM_MODEL=qwen2.5:7b

# 温度参数 (0.0-1.0)
# - 较低值(0.1-0.3): 更确定、更一致的输出
# - 较高值(0.7-0.9): 更有创意、更多样化的输出
LLM_TEMPERATURE=0.7

# 最大生成 token 数
LLM_MAX_TOKENS=2048

# 请求超时时间(秒)
LLM_TIMEOUT=60
